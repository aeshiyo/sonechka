local function SpawnFloating(name, color, text)
	if FloatingFrames[name] then
		FloatingFrames[name]:Destroy()
		FloatingFrames[name] = nil
		return
	end

	local btn = Instance.new("TextButton")
	btn.Name = "Float"..name
	btn.Size = UDim2.new(0, 65, 0, 65)
	btn.Position = FloatingPositions[name] or UDim2.new(0.5, -32, 0.5, -32)
	btn.BackgroundColor3 = States[name] and Color3.fromRGB(16, 185, 129) or color
	btn.BackgroundTransparency = 0.15
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 12
	btn.Parent = ScreenGui
	btn.Visible = true

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = btn

	local dragging = false
	local dragStart, startPos
	local clickTime = 0

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = btn.Position
			clickTime = tick()
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if dragging then
				dragging = false
				FloatingPositions[name] = btn.Position
				if tick() - clickTime < 0.2 then
					ToggleFeature(name, not States[name])
				end
			end
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			local vpSize = Workspace.CurrentCamera.ViewportSize
			local newX = math.clamp(startPos.X.Offset + delta.X, 0, vpSize.X - 65)
			local newY = math.clamp(startPos.Y.Offset + delta.Y, 0, vpSize.Y - 65)
			btn.Position = UDim2.new(0, newX, 0, newY)
		end
	end)

	FloatingFrames[name] = btn
end

