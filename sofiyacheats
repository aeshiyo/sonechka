local ToggleFuncs = {}

local function CreateToggle(name, icon, stateVar, callback)
    local frame = UIElement(Container)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -70, 1, 0)
    title.Position = UDim2.new(0, 15, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = icon .. " " .. name
    title.TextColor3 = Colors.Text
    title.Font = Enum.Font.Gotham
    title.TextSize = 20
    title.TextXAlignment = Enum.TextXAlignment.Left
    
    local indicator = Instance.new("Frame", frame)
    indicator.Size = UDim2.new(0, 24, 0, 24)
    indicator.Position = UDim2.new(1, -40, 0.5, -12)
    indicator.BackgroundColor3 = Colors.Off
    Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)
    
    local function SetState(newState)
        States[stateVar] = newState
        indicator.BackgroundColor3 = newState and Colors.On or Colors.Off
        task.spawn(callback, newState)
    end
    
    btn.MouseButton1Click:Connect(function() SetState(not States[stateVar]) end)
    ToggleFuncs[stateVar] = SetState
end

local function CreateSlider(name, min, max, defaultVar, stateVar, callback)
    local frame = UIElement(Container)
    frame.Size = UDim2.new(1, 0, 0, 75)
    
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -20, 0, 30)
    title.Position = UDim2.new(0, 10, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = name
    title.TextColor3 = Colors.Text
    title.Font = Enum.Font.Gotham
    title.TextSize = 18
    title.TextXAlignment = Enum.TextXAlignment.Left
    
    local valueTxt = Instance.new("TextLabel", frame)
    valueTxt.Size = UDim2.new(0, 40, 0, 30)
    valueTxt.Position = UDim2.new(1, -50, 0, 5)
    valueTxt.BackgroundTransparency = 1
    valueTxt.Text = tostring(States[defaultVar])
    valueTxt.TextColor3 = Colors.Accent
    valueTxt.Font = Enum.Font.GothamBold
    valueTxt.TextSize = 18
    
    local slideBg = Instance.new("Frame", frame)
    slideBg.Size = UDim2.new(1, -30, 0, 10)
    slideBg.Position = UDim2.new(0, 15, 0, 45)
    slideBg.BackgroundColor3 = Colors.LightGray
    Instance.new("UICorner", slideBg).CornerRadius = UDim.new(1, 0)
    
    local fill = Instance.new("Frame", slideBg)
    fill.Size = UDim2.new((States[defaultVar] - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = Colors.Main
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local btn = Instance.new("TextButton", slideBg)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Position = UDim2.new(0, 0, 0, -10)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    
    local isDragging = false
    local function UpdateSlider(input)
        local pos = math.clamp(input.Position.X - slideBg.AbsolutePosition.X, 0, slideBg.AbsoluteSize.X)
        local percent = pos / slideBg.AbsoluteSize.X
        local value = math.floor(min + ((max - min) * percent))
        fill.Size = UDim2.new(percent, 0, 1, 0)
        valueTxt.Text = tostring(value)
        States[defaultVar] = value
        task.spawn(callback, value)
    end
    
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            UpdateSlider(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input)
        end
    end)
    
    ToggleFuncs[defaultVar] = function(val)
        States[defaultVar] = val
        valueTxt.Text = tostring(val)
        fill.Size = UDim2.new((val - min)/(max - min), 0, 1, 0)
        task.spawn(callback, val)
    end
end

