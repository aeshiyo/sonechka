UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode == Binds.Fly then toggleLogic("Fly", not States.Fly)
		elseif input.KeyCode == Binds.Noclip then toggleLogic("Noclip", not States.Noclip)
		elseif input.KeyCode == Binds.Speed then toggleLogic("Speed", not States.Speed)
		elseif input.KeyCode == Binds.Reset then
			toggleLogic("Fly", false)
			toggleLogic("Noclip", false)
			toggleLogic("Speed", false)
			toggleLogic("FPS", false)
		end
	end
end)

RunService.Heartbeat:Connect(function()
	pcall(function()
		if States.Fly and character and humanoid and rootPart and bg and bv then
			local cam = Workspace.CurrentCamera
			local moveVector = Vector3.new(0,0,0)
			
			local s, ctrl = pcall(function() return require(lplr.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("ControlModule")) end)
			if s and ctrl then
				moveVector = ctrl:GetMoveVector()
			else
				if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Vector3.new(0,0,-1) end
				if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector + Vector3.new(0,0,1) end
				if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector + Vector3.new(-1,0,0) end
				if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Vector3.new(1,0,0) end
			end

			local flyVelocity = Vector3.new(0,0,0)
			if moveVector.Z < 0 then flyVelocity = flyVelocity + cam.CFrame.LookVector end
			if moveVector.Z > 0 then flyVelocity = flyVelocity - cam.CFrame.LookVector end
			if moveVector.X < 0 then flyVelocity = flyVelocity - cam.CFrame.RightVector end
			if moveVector.X > 0 then flyVelocity = flyVelocity + cam.CFrame.RightVector end

			if flyVelocity.Magnitude > 0 then
				bv.velocity = flyVelocity.Unit * flySpeed
			else
				bv.velocity = Vector3.new(0,0,0)
			end
			bg.cframe = cam.CFrame
		end
	end)
end)

RunService.Stepped:Connect(function()
	pcall(function()
		if States.Noclip and character then
			for _, v in pairs(character:GetDescendants()) do
				if v:IsA("BasePart") then
					if v.CanCollide then
						local found = false
						for _, data in pairs(NoclipParts) do
							if data.part == v then found = true break end
						end
						if not found then table.insert(NoclipParts, {part = v, collide = v.CanCollide}) end
					end
					v.CanCollide = false
				end
			end
		end
	end)
end)

