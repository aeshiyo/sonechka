UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    pcall(function()
        if input.KeyCode == Enum.KeyCode.F then
            if ToggleFuncs["Fly"] then ToggleFuncs["Fly"](not States.Fly) end
        elseif input.KeyCode == Enum.KeyCode.N then
            if ToggleFuncs["Noclip"] then ToggleFuncs["Noclip"](not States.Noclip) end
        elseif input.KeyCode == Enum.KeyCode.V then
            if ToggleFuncs["Speed"] then ToggleFuncs["Speed"](not States.Speed) end
        elseif input.KeyCode == Enum.KeyCode.X then
            if ToggleFuncs["Reset"] then ToggleFuncs["Reset"]() end
        end
    end)
end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char, hrp, hum = GetCharData()
        if not char or not hrp or not hum then return end
        
        if States.Fly and BV and BG then
            if hum.Health <= 0 then 
                if ToggleFuncs["Fly"] then ToggleFuncs["Fly"](false) end
                return 
            end
            BV.Velocity = Camera.CFrame.LookVector * States.FlySpeed
            BG.CFrame = Camera.CFrame
        end
        
        if States.Speed then
            hum.WalkSpeed = States.SpeedValue
        end
    end)
end)

RunService.Stepped:Connect(function()
    pcall(function()
        if States.Noclip then
            local char = Player.Character
            if char and char.Parent then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        if OriginalCollisions[v] == nil then
                            OriginalCollisions[v] = v.CanCollide
                        end
                        v.CanCollide = false
                    end
                end
            end
        end
    end)
end)

Player.CharacterAdded:Connect(function(char)
    pcall(function()
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        local hum = char:WaitForChild("Humanoid", 5)
        if not hrp or not hum then return end
        
        task.wait(0.5)
        if States.Fly then EnableFly() end
        if States.Speed then hum.WalkSpeed = States.SpeedValue end
    end)
end)

Player.CharacterRemoving:Connect(function()
    pcall(function()
        if BV then BV:Destroy(); BV = nil end
        if BG then BG:Destroy(); BG = nil end
        OriginalCollisions = {}
    end)
end)
