-- ФУНКЦИИ ЛОГИКИ (FLY, NOCLIP, SPEED)
-- ==========================================
local function GetCharData()
    local char = Player.Character
    if not char then return nil, nil, nil end
    return char, char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
end

local function EnableFly()
    local char, hrp, hum = GetCharData()
    if not char or not hrp or not hum then return end
    pcall(function()
        hum.PlatformStand = true
        BV = Instance.new("BodyVelocity", hrp)
        BV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        BV.Velocity = Vector3.new(0, 0, 0)
        
        BG = Instance.new("BodyGyro", hrp)
        BG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        BG.CFrame = hrp.CFrame
    end)
    FlyControlsUI.Visible = true
end

local function DisableFly()
    local char, hrp, hum = GetCharData()
    pcall(function()
        if hum then hum.PlatformStand = false end
        if BV then BV:Destroy(); BV = nil end
        if BG then BG:Destroy(); BG = nil end
    end)
    FlyControlsUI.Visible = false
    FlyUp = false
    FlyDown = false
end

local function ApplyNoclip(state)
    local char = Player.Character
    if not char then return end
    pcall(function()
        if state then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                    OriginalCollisions[v] = v.CanCollide
                    v.CanCollide = false
                end
            end
        else
            for part, collision in pairs(OriginalCollisions) do
                if part and part.Parent then
                    part.CanCollide = collision
                end
            end
            OriginalCollisions = {}
        end
    end)
end

