    -- === ОБРАБОТКА МОБИЛЬНЫХ КНОПОК ===
    local function makeMobileBtnDraggable(btn, actionFunc)
        local dragging = false
        local dragInput = nil
        local dragStart, startPos = nil, nil
        local hasMoved = false
        local isLocked = false
        local holdTick = 0

        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true hasMoved = false dragInput = input
                dragStart = input.Position startPos = btn.Position holdTick = tick()

                task.spawn(function()
                    while dragging and not hasMoved do
                        if tick() - holdTick >= 1.5 then
                            isLocked = not isLocked
                            btn.BackgroundColor3 = isLocked and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(15, 15, 15)
                            btn.BackgroundTransparency = isLocked and 0.7 or 0.3
                            dragging = false
                            break
                        end
                        task.wait(0.1)
                    end
                end)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                if delta.Magnitude > 10 then hasMoved = true end
                if hasMoved and not isLocked then
                    btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end
        end)

        btn.InputEnded:Connect(function(input)
            if input == dragInput then
                dragging = false
                if not hasMoved then
                    if tick() - holdTick < 1.5 then actionFunc() end
                end
            end
        end)
    end

    makeMobileBtnDraggable(FlyMobileBtn, toggleFly)
    makeMobileBtnDraggable(NoclipMobileBtn, toggleNoclip)
    makeMobileBtnDraggable(SpeedMobileBtn, toggleSpeedhack)
    makeMobileBtnDraggable(SitMobileBtn, toggleSit)
    makeMobileBtnDraggable(ShiftLockMobileBtn, toggleShiftLock)
    makeMobileBtnDraggable(SpinMobileBtn, toggleSpin)
    makeMobileBtnDraggable(LowGfxMobileBtn, toggleLowGraphics)
    makeMobileBtnDraggable(ESPMobileBtn, toggleESP)
    makeMobileBtnDraggable(AimbotMobileBtn, toggleAimbot)

    local function setupMobileShow(boolBtn, mobileBtn)
        local isShown = false
        boolBtn.MouseButton1Click:Connect(function()
            isShown = not isShown
            mobileBtn.Visible = isShown
            boolBtn.Text = isShown and "True" or "False"
            boolBtn.TextColor3 = isShown and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
            boolBtn.BackgroundColor3 = isShown and Color3.fromRGB(10, 30, 10) or Color3.fromRGB(30, 10, 10)
        end)
    end
    setupMobileShow(FlyBoolBtn, FlyMobileBtn)
    setupMobileShow(NoclipBoolBtn, NoclipMobileBtn)
    setupMobileShow(SpeedBoolBtn, SpeedMobileBtn)
    setupMobileShow(SitBoolBtn, SitMobileBtn)
    setupMobileShow(ShiftLockBoolBtn, ShiftLockMobileBtn)
    setupMobileShow(SpinBoolBtn, SpinMobileBtn)
    setupMobileShow(LowGfxBoolBtn, LowGfxMobileBtn)
    setupMobileShow(ESPBoolBtn, ESPMobileBtn)
    setupMobileShow(AimbotBoolBtn, AimbotMobileBtn)
    setupMobileShow(FOVBoolBtn, Instance.new("Frame"))

    -- === БИНДЫ С КЛАВИАТУРЫ ===
    local function setupBind(btn, keyName)
        btn.MouseButton1Click:Connect(function() btn.Text = "..." isBinding[keyName] = true end)
    end
    setupBind(FlyBindBtn, "Fly") setupBind(NoclipBindBtn, "Noclip") setupBind(SpeedBindBtn, "Speed") 
    setupBind(SitBindBtn, "Sit") setupBind(ShiftLockBindBtn, "ShiftLock") setupBind(SpinBindBtn, "Spin") 
    setupBind(LowGfxBindBtn, "LowGraphics") setupBind(ESPBindBtn, "ESP") setupBind(AimbotBindBtn, "Aimbot")
    setupBind(FOVBindBtn, "FOV")

    UserInputService.InputBegan:Connect(function(input, gp)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            for keyName, binding in pairs(isBinding) do
                if binding then
                    local btnUI = keyName == "Fly" and FlyBindBtn or keyName == "Noclip" and NoclipBindBtn or keyName == "Speed" and SpeedBindBtn or keyName == "Sit" and SitBindBtn or keyName == "ShiftLock" and ShiftLockBindBtn or keyName == "Spin" and SpinBindBtn or keyName == "LowGraphics" and LowGfxBindBtn or keyName == "ESP" and ESPBindBtn or keyName == "Aimbot" and AimbotBindBtn or FOVBindBtn
                    if input.KeyCode == Enum.KeyCode.Escape then
                        binds[keyName] = nil btnUI.Text = "[NONE]"
                    else
                        binds[keyName] = input.KeyCode btnUI.Text = "[" .. tostring(input.KeyCode):gsub("Enum.KeyCode.", "") .. "]"
                    end
                    isBinding[keyName] = false return
                end
            end
        end
        
        if not gp then
            if binds.Fly and input.KeyCode == binds.Fly then toggleFly() end
            if binds.Noclip and input.KeyCode == binds.Noclip then toggleNoclip() end
            if binds.Speed and input.KeyCode == binds.Speed then toggleSpeedhack() end
            if binds.Sit and input.KeyCode == binds.Sit then toggleSit() end
            if binds.ShiftLock and input.KeyCode == binds.ShiftLock then toggleShiftLock() end
            if binds.Spin and input.KeyCode == binds.Spin then toggleSpin() end
            if binds.LowGraphics and input.KeyCode == binds.LowGraphics then toggleLowGraphics() end
            if binds.ESP and input.KeyCode == binds.ESP then toggleESP() end
            if binds.Aimbot and input.KeyCode == binds.Aimbot then toggleAimbot() end
            if binds.FOV and input.KeyCode == binds.FOV then toggleFOV() end
        end
    end)
