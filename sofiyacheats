    local function getBestPart(char)
        for _, partName in ipairs(AimSettings.TargetParts) do
            local part = char:FindFirstChild(partName)
            if part then
                if AimSettings.WallCheck then
                    if checkVisibility(part) then return part end
                else
                    return part
                end
            end
        end
        return nil
    end

    local function getClosestTarget()
        local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

        -- Target Lock: держим текущую цель, если она в FOV и жива
        if CurrentTargetPart and CurrentTargetPart.Parent and CurrentTargetPart.Parent:FindFirstChild("Humanoid") then
            local hum = CurrentTargetPart.Parent.Humanoid
            if hum.Health > 0 then
                local partPos, onScreen = Camera:WorldToViewportPoint(CurrentTargetPart.Position)
                local distance = (Vector2.new(partPos.X, partPos.Y) - screenCenter).Magnitude
                
                if onScreen and distance <= AimSettings.FOVRadius then
                    if AimSettings.WallCheck then
                        if checkVisibility(CurrentTargetPart) then return CurrentTargetPart end
                    else
                        return CurrentTargetPart
                    end
                end
            end
        end

        -- Если старой цели нет, выбираем новую ближайшую к центру
        CurrentTargetPart = nil
        local closestTarget = nil
        local shortestDistance = AimSettings.FOVRadius
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if AimSettings.TeamCheck and player.Team == LocalPlayer.Team then continue end
                local char = player.Character
                local hum = char and char:FindFirstChild("Humanoid")
                if char and hum and hum.Health > 0 then
                    local targetPart = getBestPart(char)
                    if targetPart then
                        local partPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                        if onScreen then
                            local distance = (Vector2.new(partPos.X, partPos.Y) - screenCenter).Magnitude
                            if distance < shortestDistance then
                                shortestDistance = distance
                                closestTarget = targetPart
                            end
                        end
                    end
                end
            end
        end
        
        CurrentTargetPart = closestTarget
        return closestTarget
    end

    -- Перехват рендера камеры с поддержкой dt (DeltaTime)
    RunService:BindToRenderStep("SonyaAimbotLoop", Enum.RenderPriority.Camera.Value + 1, function(dt)
        FOVCircle.Radius = AimSettings.FOVRadius
        
        local condition = AimSettings.Enabled and (isAiming or UserInputService.TouchEnabled)
        
        if condition then
            local target = getClosestTarget()
            if target then
                -- Prediction убран: наводка идет строго в исходную позицию кости персонажа
                local aimPosition = target.Position
                
                local currentCFrame = Camera.CFrame
                local targetCFrame = CFrame.new(currentCFrame.Position, aimPosition)
                
                -- Сглаживание привязано к времени кадра, аим не будет дёргаться на разном FPS
                local lerpAlpha = math.clamp(dt * (AimSettings.Smoothness * 60), 0, 1)
                Camera.CFrame = currentCFrame:Lerp(targetCFrame, lerpAlpha)
            end
        else
            CurrentTargetPart = nil
        end
    end)

