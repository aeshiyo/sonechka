    local isFlying, bg, bv = false, nil, nil
    local function toggleFly()
        isFlying = not isFlying
        if isFlying then
            FlyToggle.BackgroundColor3 = Color3.fromRGB(10, 30, 10)
            FlyStroke.Color = Color3.fromRGB(50, 150, 50)
            FlyMobileBtn.BackgroundColor3 = Color3.fromRGB(10, 30, 10)
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
                char.Humanoid.PlatformStand = true
                bg = Instance.new("BodyGyro", char.HumanoidRootPart)
                bg.P = 9e4 bg.maxTorque = Vector3.new(9e9, 9e9, 9e9) bg.cframe = char.HumanoidRootPart.CFrame
                bv = Instance.new("BodyVelocity", char.HumanoidRootPart)
                bv.velocity = Vector3.new(0,0,0) bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
                
                RunService:BindToRenderStep("SonyaFly", Enum.RenderPriority.Camera.Value, function()
                    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                    local md = Vector3.new(0,0,0)
                    pcall(function()
                        local playerModule = require(LocalPlayer:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"))
                        local controls = playerModule:GetControls()
                        local moveVector = controls:GetMoveVector()
                        md = (Camera.CFrame.RightVector * moveVector.X) + (Camera.CFrame.LookVector * -moveVector.Z)
                    end)
                    if md.Magnitude == 0 then
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then md = md + Camera.CFrame.LookVector end
