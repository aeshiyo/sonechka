-- ==========================================
-- ИГРОВЫЕ ЦИКЛЫ И СОБЫТИЯ
-- ==========================================
RunService.Heartbeat:Connect(function()
    pcall(function()
        local char, hrp, hum = GetCharData()
        if not char or not hrp or not hum then return end
        
        -- Fly Logic
        if States.Fly and BV and BG then
            if hum.Health <= 0 then 
                ToggleFuncs["Fly"](false) 
                return 
            end
            
            local camDir = Camera.CFrame.LookVector
            local moveVec = Vector3.new(0, 0, 0)
            
            if FlyUp then moveVec = camDir * States.FlySpeed end
            if FlyDown then moveVec = camDir * -States.FlySpeed end
            
            BV.Velocity = moveVec
            BG.CFrame = Camera.CFrame
        end
        
        -- Speed Logic
        if States.Speed and hum then
            hum.WalkSpeed = States.SpeedValue
        end
    end)
end)

-- Noclip Logic (выполняется на Stepped, чтобы движок не переписывал коллизии)
RunService.Stepped:Connect(function()
    pcall(function()
        if States.Noclip then
            local char = Player.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                        v.CanCollide = false
                    end
                end
            end
        end
    end)
end)

-- Обработка смерти/перерождения
Player.CharacterAdded:Connect(function(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hrp or not hum then return end
    
    task.wait(0.5) -- Ждём прогрузки физики
    if States.Fly then
        EnableFly()
    end
    if States.Noclip then
        ApplyNoclip(true)
    end
    if States.Speed then
        hum.WalkSpeed = States.SpeedValue
    end
end)

Player.CharacterRemoving:Connect(function()
    if BV then BV:Destroy(); BV = nil end
    if BG then BG:Destroy(); BG = nil end
    OriginalCollisions = {}
end)
