local function SetupSlider(bgBtn, fill, textLbl, min, max, statName)
	local dragging = false
	bgBtn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local mouseX = input.Position.X
			local absPos = bgBtn.AbsolutePosition.X
			local absSize = bgBtn.AbsoluteSize.X
			local percent = math.clamp((mouseX - absPos) / absSize, 0, 1)
			fill.Size = UDim2.new(percent, 0, 1, 0)
			local val = math.floor(min + ((max - min) * percent))
			textLbl.Text = tostring(val)
			Values[statName] = val
			if statName == "Speed" and States.Speed and humanoid then
				humanoid.WalkSpeed = val
			end
		end
	end)
end

