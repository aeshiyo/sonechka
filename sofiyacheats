local function ToggleFeature(name, state)
	States[name] = state
	local btn, textIcon, activeColor
	if name == "Fly" then btn = FlyBtn; textIcon = "🚀 FLY"; activeColor = Color3.fromRGB(139, 92, 246)
	elseif name == "Noclip" then btn = NoclipBtn; textIcon = "👻 NOCLIP"; activeColor = Color3.fromRGB(59, 130, 246)
	elseif name == "Speed" then btn = SpeedBtn; textIcon = "⚡ SPEED"; activeColor = Color3.fromRGB(245, 158, 11)
	elseif name == "FPS" then btn = FpsBtn; textIcon = "🎮 BUST FPS"; activeColor = Color3.fromRGB(16, 185, 129)
	end

	if btn then
		if state then
			btn.Text = textIcon .. " [ВКЛ]"
			btn.TextColor3 = Color3.fromRGB(16, 185, 129)
		else
			btn.Text = textIcon .. " [ВЫКЛ]"
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end

	if FloatingFrames[name] then
		FloatingFrames[name].BackgroundColor3 = state and Color3.fromRGB(16, 185, 129) or activeColor
	end

	pcall(function()
		if name == "Fly" then
			if state then
				if not character or not rootPart or not humanoid then return end
				humanoid.PlatformStand = true
				bg = Instance.new("BodyGyro")
				bg.P = 9e4
				bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
				bg.cframe = rootPart.CFrame
				bg.Parent = rootPart
				bv = Instance.new("BodyVelocity")
				bv.velocity = Vector3.new(0, 0, 0)
				bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
				bv.Parent = rootPart
			else
				if humanoid then humanoid.PlatformStand = false end
				if bg then bg:Destroy() end
				if bv then bv:Destroy() end
			end
		elseif name == "Noclip" then
			if not state then
				for _, data in pairs(NoclipParts) do
					if data.part and data.part.Parent then
						data.part.CanCollide = data.collide
					end
				end
				NoclipParts = {}
			end
		elseif name == "Speed" then
			if state then
				if humanoid then humanoid.WalkSpeed = Values.Speed end
			else
				if humanoid then humanoid.WalkSpeed = 16 end
			end
		elseif name == "FPS" then
			if state then
				OldLighting.Technology = Lighting.Technology
				OldLighting.GlobalShadows = Lighting.GlobalShadows
				OldLighting.ClockTime = Lighting.ClockTime
				local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
				OldLighting.Bloom = bloom and bloom.Enabled or false
				local atmos = Lighting:FindFirstChildOfClass("Atmosphere")
				OldLighting.Atmosphere = atmos
				OldLighting.FOV = Workspace.CurrentCamera.FieldOfView

				pcall(function() Lighting.Technology = Enum.Technology.Compatibility end)
				pcall(function() Lighting.GlobalShadows = false end)
				pcall(function() Lighting.ClockTime = 12 end)
				if bloom then pcall(function() bloom.Enabled = false end) end
				if atmos then pcall(function() atmos.Parent = nil end) end
				pcall(function() Workspace.CurrentCamera.FieldOfView = 70 end)

				task.spawn(function()
					for _, v in pairs(Workspace:GetDescendants()) do
						pcall(function()
							if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
								v.Enabled = false
							elseif v:IsA("Texture") or v:IsA("Decal") then
								v.Texture = ""
							end
						end)
					end
				end)
			else
				pcall(function() Lighting.Technology = OldLighting.Technology or Enum.Technology.ShadowMap end)
				pcall(function() Lighting.GlobalShadows = OldLighting.GlobalShadows or true end)
				pcall(function() Lighting.ClockTime = OldLighting.ClockTime or 14 end)
				local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
				if bloom then pcall(function() bloom.Enabled = OldLighting.Bloom end) end
				if OldLighting.Atmosphere then pcall(function() OldLighting.Atmosphere.Parent = Lighting end) end
				pcall(function() Workspace.CurrentCamera.FieldOfView = OldLighting.FOV or 70 end)
			end
		end
	end)
end

